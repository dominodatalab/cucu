{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Renovate config",
  "extends": [
    "config:best-practices"
  ],
  "additionalBranchPrefix": "{{date}}",
  "ignorePaths": [
    "**/.python-version"
  ],
  "minimumReleaseAge": "14 days",
  "lockFileMaintenance": {
    "enabled": false
  },
  "packageRules": [
    {
      "matchCategories": [
        "python"
      ],
      "enabled": true
    },
    {
      "groupName": "all dependencies",
      "matchFileNames": [
        "**"
      ],
      "automerge": true,
      "platformAutomerge": true,
      "matchUpdateTypes": [
        "major",
        "minor",
        "patch",
        "digest",
        "pin"
      ]
    },
    {
      "description": "Ignore behave and selenium version updates due to compatibility issues",
      "matchDatasources": [
        "pypi"
      ],
      "matchPackageNames": [
        "behave",
        "selenium"
      ],
      "enabled": false
    },
    {
      "description": "Ignore selenium Docker image updates",
      "matchDatasources": [
        "docker"
      ],
      "matchPackagePatterns": [
        "^selenium/"
      ],
      "enabled": false
    },
    {
      "description": "Ignore minor Python version updates",
      "matchFileNames": [
        "**Dockerfile",
        ".circleci/config.yml",
        ".github/workflows/*.yml"
      ],
      "matchDatasources": [
        "pyenv",
        "docker",
        "pypi"
      ],
      "matchPackageNames": [
        "cimg/python",
        "python"
      ],
      "matchUpdateTypes": [
        "minor"
      ],
      "enabled": false
    }
  ]
}
